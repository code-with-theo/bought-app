{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bought-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bought",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "bought-images"
    }
  ]
}
