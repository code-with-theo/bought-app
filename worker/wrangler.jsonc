{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bought-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "vars": {
    "ALLOWED_ORIGINS": "https://bought-app.catzen.workers.dev,capacitor://localhost"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bought",
      "database_id": "f6e3d0ee-6659-4bee-9a75-1a456c2a6b96",
      "migrations_dir": "migrations"
    }
  ]
}
